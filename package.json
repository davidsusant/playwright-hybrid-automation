{
  "name": "playwright-hybrid-automation",
  "version": "1.0.0",
  "description": "Playwright + TypeScript UI & API automation framework for automationintesting.online and restful-booker.herokuapp.com",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui-chromium",
    "test:api": "playwright test --project=api",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "report": "playwright show-report",
    "codegen": "playwright codegen http://automationintesting.online/",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/davidsusant/playwright-hybrid-automation.git"
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "api-testing",
    "ui-testing",
    "qa"
  ],
  "author": "davidsusanto",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/davidsusant/playwright-hybrid-automation/issues",
    "email": "davidsusanto.id@gmail.com"
  },
  "homepage": "https://github.com/davidsusant/playwright-hybrid-automation#readme",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.13.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.4",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
